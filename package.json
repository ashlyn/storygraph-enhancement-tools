{
  "name": "storygraph-enhancement-tools",
  "version": "4.3.1",
  "description": "Adds some helpful UI elements, such as direct links to search your local library, to The StoryGraph.",
  "scripts": {
    "start": "webpack --watch --config webpack.dev.cjs",
    "build": "webpack --config webpack.prod.cjs --env target=['chromium', 'firefox-desktop', 'firefox-android']",
    "lint": "eslint --ext .ts,.js --max-warnings=0 .",
    "prettier": "prettier --write '{src,static}/**/*.{ts,js,css,scss,json,html}'",
    "test": "c8 mocha ./test/setup.js",
    "watch:chrome": "webpack --watch --config webpack.dev.cjs --env target='chromium'",
    "watch:firefox": "webpack --watch --config webpack.dev.cjs --env target='firefox'",
    "watch:mobile": "env-cmd -x -- webpack --watch --config webpack.dev.cjs --env target='firefox-android' --env adbDevice=\\$ADB_DEVICE",
    "watch:web": "webpack --watch --config webpack.dev.cjs"
  },
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-typescript": "8.0.1",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/mocha": "10.0.10",
    "@types/webextension-polyfill": "0.12.5",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "babel-loader": "10.1.1",
    "babel-plugin-polyfill-corejs3": "1.0.0",
    "c8": "11.0.0",
    "copy-webpack-plugin": "14.0.0",
    "core-js": "3.49.0",
    "css-loader": "7.1.4",
    "dotenv-webpack": "9.0.0",
    "env-cmd": "11.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-webpack-plugin": "6.0.0",
    "expect.js": "0.3.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "mini-css-extract-plugin": "2.10.2",
    "mocha": "11.7.6",
    "prettier": "3.9.4",
    "sass": "1.101.0",
    "sass-loader": "17.0.0",
    "sinon-chrome": "3.0.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "web-ext-plugin": "2.13.0",
    "webextension-polyfill": "0.12.0",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-merge": "6.0.1"
  },
  "dependencies": {
    "@babel/runtime": "8.0.0",
    "normalize.css": "8.0.1"
  },
  "overrides": {
    "diff": "9.0.0",
    "glob": "13.0.6",
    "serialize-javascript": "7.0.7"
  },
  "browserslist": "> 0.25%, not dead",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "npm run prettier",
      "npm run lint"
    ]
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "core-js@3.49.0": true,
    "@parcel/watcher@2.5.6": true
  }
}
